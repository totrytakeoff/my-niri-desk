#!/usr/bin/env bash
set -euo pipefail

pkg_root="/usr/share/my-niri-desk"
template_root="${pkg_root}/skel"
backup_root="${HOME}/.local/share/my-niri-desk/backups/$(date +%Y%m%d-%H%M%S)"

if [[ ! -d "${template_root}" ]]; then
  echo "my-niri-desk template payload not found: ${template_root}" >&2
  exit 1
fi

mkdir -p "${backup_root}"
mkdir -p "${HOME}/Pictures/Screenshots"
mkdir -p "${HOME}/Pictures/wallpapers"
mkdir -p "${HOME}/.config/wallpaper"
mkdir -p "${HOME}/.local/share/backgrounds/generated"
mkdir -p "${HOME}/.cache/wallpaper_rofi"

backup_if_exists() {
  local path="$1"
  if [[ -e "${path}" || -L "${path}" ]]; then
    mkdir -p "${backup_root}/$(dirname "${path#${HOME}/}")"
    cp -a "${path}" "${backup_root}/${path#${HOME}/}"
  fi
}

for rel in \
  ".config/niri" \
  ".config/quickshell" \
  ".config/wallpaper" \
  ".config/fcitx5" \
  ".config/hypr" \
  ".config/fuzzel" \
  ".config/mako" \
  ".local/share/fcitx5/themes/NiriGlass"
do
  backup_if_exists "${HOME}/${rel}"
done

cp -a "${template_root}/." "${HOME}/"

# Ensure the package-managed default wallpaper set is always present.
# Overwrite same-name defaults but keep any user-added wallpapers intact.
if [[ -d "${template_root}/.config/wallpaper" ]]; then
  cp -af "${template_root}/.config/wallpaper/." "${HOME}/.config/wallpaper/"
fi

find "${HOME}/.config/niri/scripts" -type f -exec chmod +x {} +
find "${HOME}/.config/quickshell/scripts" -type f -exec chmod +x {} +

sed -i "s|@HOME@|${HOME}|g" "${HOME}/.config/hypr/hyprlock.conf"

if [[ ! -e "${HOME}/.face.icon" ]]; then
  if [[ -f /usr/share/pixmaps/faces/user-avatar ]]; then
    ln -sf /usr/share/pixmaps/faces/user-avatar "${HOME}/.face.icon"
  elif [[ -f /usr/share/pixmaps/archlinux-logo.png ]]; then
    ln -sf /usr/share/pixmaps/archlinux-logo.png "${HOME}/.face.icon"
  fi
fi

fc-cache -f >/dev/null 2>&1 || true

cat <<EOF
Applied my-niri-desk to:
  ${HOME}

Backup saved to:
  ${backup_root}

Next:
  1. Log out
  2. Choose the Niri session
  3. Log back in

Wallpaper defaults:
  ${HOME}/.config/wallpaper
EOF
